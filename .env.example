# Copy this file to .env and fill in real values.
# Generate values with: bash scripts/gen-secrets.sh

# BookStack encryption key — must be "base64:" + 32 random bytes base64-encoded.
# Generate with:  echo "base64:$(openssl rand -base64 32)"
APP_KEY=base64:REPLACE_ME

# MariaDB root password (only used for DB container init)
DB_ROOT_PASSWORD=REPLACE_ME

# MariaDB user password (BookStack connects with this)
DB_PASSWORD=REPLACE_ME
