# Copy this file to .env and fill in real values.
# Generate values with:  bash scripts/gen-secrets.sh > .env

# MariaDB
DB_ROOT_PASSWORD=REPLACE_ME
DB_PASSWORD=REPLACE_ME

# Initial Nextcloud admin account.
# Auto-created on first boot. Change inside the UI later if you want.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=REPLACE_ME
